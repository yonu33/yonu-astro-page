---
const brandConfig = {
  github:  { color: "group-hover:text-[#181717] dark:group-hover:text-white", border: "group-hover:border-[#181717] dark:group-hover:border-white" },
  x:       { color: "group-hover:text-[#000000] dark:group-hover:text-white", border: "group-hover:border-[#000000] dark:group-hover:border-white" },
  qiita:   { color: "group-hover:text-[#55c500]", border: "group-hover:border-[#55c500]" },
  zenn:    { color: "group-hover:text-[#3ea8ff]", border: "group-hover:border-[#3ea8ff]" },
  note:    { color: "group-hover:text-[#2cb696]", border: "group-hover:border-[#2cb696]" },
  discord: { color: "group-hover:text-[#5865F2]", border: "group-hover:border-[#5865F2]" }
};

import githubSvg from '../assets/icons/github.svg?raw';
import xSvg from '../assets/icons/x.svg?raw';
import qiitaSvg from '../assets/icons/qiita.svg?raw';
import zennSvg from '../assets/icons/zenn.svg?raw';
import noteSvg from '../assets/icons/note.svg?raw';
import discordSvg from '../assets/icons/discord.svg?raw';

const socials = [
  { id: "github",  name: "GitHub",  url: "https://github.com/yonu33", svg: githubSvg },
  { id: "x",       name: "X",       url: "https://x.com/i/user/1898003250068262912", svg: xSvg },
  { id: "qiita",   name: "Qiita",   url: "https://qiita.com/yonu", svg: qiitaSvg },
  { id: "zenn",    name: "Zenn",    url: "https://zenn.dev/yonu", svg: zennSvg },
  { id: "note",    name: "note",    url: "https://note.com/yonu33", svg: noteSvg },
  { id: "discord", name: "Discord", url: "https://discord.com/invite/9ZCgqNzqF7", svg: discordSvg }
];
---

<div class="flex flex-wrap gap-3 mb-16">
  {socials.map(link => {
    const style = brandConfig[link.id];
    
    return (
      <a 
        href={link.url} 
        target="_blank" 
        class={`w-11 h-11 aspect-square flex items-center justify-center p-2.5 bg-[var(--bg-card)] border border-[var(--border-color)] rounded-xl transition-all shadow-sm group ${style.border}`}
        title={link.name}
      >
        <div class={`w-full h-full text-[var(--text-muted)] transition-colors ${style.color}`}>
          <Fragment set:html={link.svg} />
        </div>
      </a>
    );
  })}
</div>

<style is:global>
  svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }
</style>