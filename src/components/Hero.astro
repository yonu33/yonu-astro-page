---
const profile = {
  name: "yonu (yonu33)",
  bio: "会津大学コンピュータ理工学部 33期生 (UoA33)",
  role: "GDGoC Aizu Co-Organizer / UoA Hub Administrator",
  avatar: "https://avatars.githubusercontent.com/u/175496140"
};
---

<header class="flex flex-col items-center md:items-start gap-6 mb-12 md:mb-16">
  <img 
    src={profile.avatar} 
    alt={profile.name} 
    class="w-24 h-24 md:w-32 md:h-32 rounded-full border-4 border-[var(--bg-card)] shadow-xl dark:shadow-none transition-transform duration-500 hover:scale-105"
  />
  
  <div class="text-center md:text-left px-2 md:px-0">
    <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight text-[var(--text-main)] mb-2">
      {profile.name}
    </h1>
    <p class="text-base md:text-xl text-[var(--text-muted)] font-medium italic leading-relaxed">
      {profile.bio}
    </p>
    <p class="text-[10px] md:text-sm text-slate-400 dark:text-slate-500 mt-3 md:mt-2 font-mono uppercase tracking-[0.2em]">
      {profile.role}
    </div>
</header>