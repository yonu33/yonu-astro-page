<script is:inline>
  const DISCORD_ID = "1347610481233494139"; 

  async function updateLanyard() {
    try {
      const res = await fetch(`https://api.lanyard.rest/v1/users/${DISCORD_ID}`);
      const { data } = await res.json();
      
      const container = document.getElementById('status-container');
      const text = document.getElementById('status-text');

      const activity = data.activities.find(a => a.name === "Visual Studio Code") || 
                       data.activities.find(a => a.type === 0) || 
                       data.activities.find(a => a.type === 2);

      if (activity) {
        let icon = "🎮";
        let displayTitle = activity.name;

        if (activity.name === "Visual Studio Code") {
          icon = "💻";
          displayTitle = activity.details || "Coding";
        } else if (activity.name === "YouTube Music" || activity.type === 2) {
          icon = "🎵";
          displayTitle = activity.details || "Music";
        }

        const newText = `${icon} ${displayTitle}`;
        
        if (text.innerText !== newText) {
          text.innerText = newText;
        }
        
        container.classList.remove('opacity-0');
        container.classList.add('opacity-100');
      } else {
        container.classList.remove('opacity-100');
        container.classList.add('opacity-0');
      }
    } catch (e) {
      console.error("Lanyard API Error:", e);
    }
  }

  updateLanyard();
  setInterval(updateLanyard, 15000);
</script>