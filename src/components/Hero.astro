---
const profile = {
  name: "yonu (yonu33)",
  bio: "会津大学コンピュータ理工学部 33期生 (UoA33)",
  role: "GDGoC Aizu Co-Organizer / UoA Hub Administrator",
  avatar: "https://avatars.githubusercontent.com/u/175496140"
};
---

<header class="flex flex-col items-center md:items-start gap-6 mb-16">
  <img 
    src={profile.avatar} 
    alt={profile.name} 
    class="w-24 h-24 md:w-32 md:h-32 rounded-full border-4 border-white shadow-xl"
  />
  
  <div class="text-center md:text-left">
    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 mb-2">
      {profile.name}
    </h1>
    <p class="text-lg md:text-xl text-slate-500 font-medium italic">
      {profile.bio}
    </p>
    <p class="text-sm text-slate-400 mt-2 font-mono uppercase tracking-widest">
      {profile.role}
    </p>
  </div>
</header>