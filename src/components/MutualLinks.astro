---
const mutualLinks = [
  { 
    name: "柴犬被り 氏", 
    url: "https://memo.shibadogcap.com/"
  },
  { 
    name: "トラマト 氏", 
    url: "https://toramutton.me/"
  }
];

const getFavicon = (siteUrl) => {
  const domain = new URL(siteUrl).hostname;
  return `https://images.weserv.nl/?url=https://www.google.com/s2/favicons?domain=${domain}&sz=128&lbc=1`;
};
---

<section class="mb-20 pt-16 border-t border-[var(--border-color)]">
  <h2 class="text-xs uppercase tracking-[0.2em] text-[var(--text-muted)] font-bold mb-8 italic">■ Mutual Links</h2>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {mutualLinks.map(site => (
      <a 
        href={site.url} 
        target="_blank" 
        class="group flex items-center gap-4 p-4 bg-[var(--bg-card)] border border-[var(--border-color)] rounded-2xl hover:border-blue-500 transition-all duration-300"
      >
        <div class="w-12 h-12 shrink-0 flex items-center justify-center bg-white/5 dark:bg-slate-700/50 rounded-xl overflow-hidden border border-[var(--border-color)]">
          <img src={getFavicon(site.url)} alt="" class="w-7 h-7 object-contain" />
        </div>
        <div class="overflow-hidden">
          <h3 class="font-bold text-[var(--text-main)] truncate">{site.name}</h3>
          <p class="text-[10px] text-[var(--text-muted)] font-mono truncate">{site.url.replace(/^https?:\/\//, '')}</p>
        </div>
      </a>
    ))}
  </div>
</section>