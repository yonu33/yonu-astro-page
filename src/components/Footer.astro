---
const currentYear = new Date().getFullYear();
---

<footer class="mt-32 pb-16 border-t border-[var(--border-color)]">
  <div class="max-w-3xl mx-auto px-6 pt-12 text-center">
    <p class="text-[11px] font-mono text-[var(--text-muted)] tracking-wider mb-3">
      © 2025 - {currentYear} yonu33. All rights reserved.
    </p>
    
    <p class="text-[9px] font-mono text-slate-400/50 dark:text-slate-500/50 tracking-wide italic">
      Mutual links welcome!
    </p>
  </div>
</footer>