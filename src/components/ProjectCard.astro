---
const { project, variant = "compact" } = Astro.props;
---

{variant === "compact" ? (
  <a href={`/projects#${project.id}`} class="group block">
    <div class="p-4 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)] shadow-sm flex flex-col md:flex-row md:items-center gap-2 md:gap-6 group-hover:border-blue-500 group-hover:shadow-md transition-all duration-300 active:scale-[0.99]">
      <span class="text-[10px] md:text-xs font-mono text-[var(--text-muted)] md:w-32 shrink-0">
        {project.period}
      </span>
      
      <div class="flex-1 min-w-0">
        <span class="font-bold text-[var(--text-main)] block md:inline md:mr-2 group-hover:text-blue-500 transition-colors truncate md:whitespace-normal">
          {project.title}
        </span>
        <span class="text-sm text-[var(--text-muted)] group-hover:text-[var(--text-main)] transition-colors block md:inline line-clamp-1 md:line-clamp-none">
          {project.description}
        </span>
      </div>
    </div>
  </a>
) : (
  <section id={project.id} class="group scroll-mt-24 px-1">
    </section>
)}