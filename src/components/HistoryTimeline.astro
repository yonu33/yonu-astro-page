---
const { history } = Astro.props;
---
<div class="space-y-6">
  {history.map(item => (
    /* flex-col (スマホ) / md:flex-row (PC) に切り替え */
    <div class="flex flex-col md:flex-row md:gap-4 border-l-2 border-[var(--border-color)] pl-4 hover:border-[#008578] transition-colors group">
      
      <span class="text-[10px] md:text-xs font-mono text-[var(--text-muted)] pt-0.5 mb-1 md:mb-0 shrink-0 w-24">
        {item.date}
      </span>

      {item.href ? (
        <a 
          href={item.href} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="text-sm text-[var(--text-main)] opacity-80 group-hover:opacity-100 group-hover:text-[#008578] transition-all underline decoration-[var(--border-color)] underline-offset-4 hover:decoration-[#008578] leading-snug"
        >
          {item.text}
        </a>
      ) : (
        <span class="text-sm text-[var(--text-main)] opacity-80 leading-snug">
          {item.text}
        </span>
      )}
    </div>
  ))}
</div>